<script setup lang="ts">
import { ref, computed, h } from "vue"

const user = "Gabriel"

/* datas base */
const today = new Date()
today.setHours(0, 0, 0, 0)

/* data selecionada (SÓ CLIQUE) */
const selectedDate = ref(new Date(today))

/* deslocamento do calendário (SETAS) */
const dayOffset = ref(0)

const habits = ref([
  { id: 1, name: "Beber água", done: false },
  { id: 2, name: "Estudar Vue.js", done: false },
  { id: 3, name: "Caminhada 20 min", done: false },
])

const labels = ["Dom", "Seg", "Ter", "Qua", "Qui", "Sex", "Sáb"]

function isSameDay(a: Date, b: Date) {
  return (
    a.getFullYear() === b.getFullYear() &&
    a.getMonth() === b.getMonth() &&
    a.getDate() === b.getDate()
  )
}

/* ===== PROGRESSO ===== */
const completedCount = computed(() =>
  habits.value.filter(h => h.done).length
)

const progressPercent = computed(() => {
  if (habits.value.length === 0) return 0
  return Math.round((completedCount.value / habits.value.length) * 100)
})

const days = computed(() => {
  const yesterday = new Date(today)
  yesterday.setDate(today.getDate() - 1)

  return Array.from({ length: 7 }).map((_, i) => {
    const date = new Date(
      today.getFullYear(),
      today.getMonth(),
      today.getDate() + i - 3 + dayOffset.value
    )

    return {
      date,
      label: labels[date.getDay()],
      day: date.getDate(),
      isToday: isSameDay(date, today),
      isYesterday: isSameDay(date, yesterday),
      isSelected: isSameDay(date, selectedDate.value),
    }
  })
})

function prevDay() {
  dayOffset.value--
}

function nextDay() {
  dayOffset.value++
}

function selectDay(date: Date) {
  selectedDate.value = new Date(date)
}
</script>

<template>
  <div class="app">

    <!-- CARD PRINCIPAL -->
    <div class="card">
      <!-- HEADER -->
      <header class="header">
        <h3>Bom dia, {{ user }}</h3>
        <button class="add-btn">+</button>
      </header>

      <!-- DAYS -->
      <section class="days">
        <button class="arrow" @click="prevDay">‹</button>

        <div
          v-for="(d, i) in days"
          :key="i"
          class="day"
          :class="{ active: d.isSelected }"
          @click="selectDay(d.date)"
        >
          <span v-if="d.isYesterday" class="crown">👑</span>
          <span v-if="d.isToday" class="today-dot"></span>

          <span class="label">{{ d.label }}</span>
          <span class="number">{{ d.day }}</span>
        </div>

        <button class="arrow" @click="nextDay">›</button>
      </section>

      <!-- PROGRESS -->
      <div class="progress-bar">
        <div
          class="progress-fill"
          :style="{ width: progressPercent + '%' }"
        />
      </div>

      <!-- HABITS -->
      <section class="habits">
        <div
          v-for="h in habits"
          :key="h.id"
          class="habit"
          @click="h.done = !h.done"
        >
          <input type="checkbox" v-model="h.done" @click.stop />
          <span :class="{ done: h.done }">{{ h.name }}</span>
        </div>
      </section>

      <!-- FOOTER -->
      <footer class="app-footer">
        <span>v0.1.0</span>
        <span class="footer-links">
          <a href="#">GitHub</a>
          <a href="#">Docs</a>
          <a href="#">About</a>
        </span>
      </footer>
    </div>
  </div>
</template>

